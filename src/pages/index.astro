---
import "../styles/global.css";
export const prerender = true;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Starlight Detector</title>
    </head>
    <body class="bg-black min-h-screen flex items-center justify-center p-4">
        <div class="w-full max-w-md">
            <div
                class="glass-card p-8 rounded-2xl backdrop-blur-xl bg-zinc-900/50 border border-zinc-800/50 shadow-2xl"
            >
                <div class="mb-8 text-center">
                    <h1 class="text-3xl font-bold text-white mb-2">
                        Starlight Detector
                    </h1>
                    <p class="text-zinc-400 text-sm">
                        Check if a website uses
                        <a
                            href="https://starlight.astro.build/"
                            class="text-zinc-300 underline hover:text-zinc-200"
                        >
                            Astro Starlight
                        </a>
                    </p>
                </div>

                <form id="check-form" class="space-y-4">
                    <div>
                        <input
                            type="url"
                            id="url-input"
                            placeholder="https://example.com"
                            required
                            class="w-full px-4 py-3 bg-zinc-950/50 border border-zinc-800 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-700 focus:border-transparent transition-all"
                        />
                    </div>

                    <button
                        type="submit"
                        class="w-full px-4 py-3 bg-zinc-800 hover:bg-zinc-700 text-white rounded-lg font-medium transition-all focus:outline-none focus:ring-2 focus:ring-zinc-600 disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                        Check Site
                    </button>
                </form>

                <div id="result" class="mt-6 hidden">
                    <div class="p-4 rounded-lg border" id="result-content">
                    </div>
                </div>

                <div id="loading" class="mt-6 hidden">
                    <div
                        class="flex items-center justify-center space-x-2 text-zinc-400"
                    >
                        <div
                            class="animate-spin rounded-full h-4 w-4 border-2 border-zinc-400 border-t-transparent"
                        >
                        </div>
                        <span class="text-sm">Checking...</span>
                    </div>
                </div>

                <div
                    class="mt-10 p-4 rounded-lg border border-zinc-800 bg-zinc-900/40"
                >
                    <p class="text-zinc-300 text-sm mb-2 font-medium">
                        Use the API directly
                    </p>
                    <p class="text-zinc-500 text-xs mb-3">
                        If you want to use the API in your code directly, call
                        it like this:
                    </p>

                    <div class="relative group">
                        <pre
                            class="text-xs bg-zinc-950/60 border border-zinc-800 p-3 pr-12 rounded-lg text-zinc-300 overflow-x-auto">https://starlight-detector.trueberryless.org/api/check-starlight?url=https://&lt;your-website&gt;   </pre>

                        <div
                            class="pointer-events-none absolute top-px bottom-px right-px rounded-lg w-28 h-full bg-linear-to-r from-transparent to-zinc-950"
                        >
                        </div>

                        <button
                            onclick="navigator.clipboard.writeText('https://starlight-detector.trueberryless.org/api/check-starlight?url=https://')"
                            class="absolute top-2 right-2 bg-zinc-950 text-zinc-400 hover:text-white text-xs border border-zinc-700 px-2 py-1 rounded transition"
                        >
                            Copy
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            const form = document.getElementById(
                "check-form",
            ) as HTMLFormElement;
            const input = document.getElementById(
                "url-input",
            ) as HTMLInputElement;
            const resultDiv = document.getElementById(
                "result",
            ) as HTMLDivElement;
            const resultContent = document.getElementById(
                "result-content",
            ) as HTMLDivElement;
            const loadingDiv = document.getElementById(
                "loading",
            ) as HTMLDivElement;

            form.addEventListener("submit", async (e) => {
                e.preventDefault();

                const url = input.value.trim();
                if (!url) return;

                resultDiv.classList.add("hidden");
                loadingDiv.classList.remove("hidden");

                try {
                    const response = await fetch(
                        `/api/check-starlight?url=${encodeURIComponent(url)}`,
                    );
                    const data = await response.json();

                    loadingDiv.classList.add("hidden");
                    resultDiv.classList.remove("hidden");

                    if (data.error) {
                        resultContent.className =
                            "p-4 rounded-lg border border-red-900/50 bg-red-950/20";
                        resultContent.innerHTML = `
            <p class="text-red-400 text-sm font-medium">Error</p>
            <p class="text-red-300/70 text-sm mt-1">${data.error}</p>
          `;
                    } else if (data.isStarlight) {
                        resultContent.className =
                            "p-4 rounded-lg border border-green-900/50 bg-green-950/20";
                        resultContent.innerHTML = `
            <p class="text-green-400 text-sm font-medium">✓ Starlight Detected</p>
            <p class="text-green-300/70 text-sm mt-1">Version: ${data.version}</p>
          `;
                    } else {
                        resultContent.className =
                            "p-4 rounded-lg border border-zinc-800 bg-zinc-900/30";
                        resultContent.innerHTML = `
            <p class="text-zinc-400 text-sm">Not using Starlight</p>
          `;
                    }
                } catch (error) {
                    loadingDiv.classList.add("hidden");
                    resultDiv.classList.remove("hidden");
                    resultContent.className =
                        "p-4 rounded-lg border border-red-900/50 bg-red-950/20";
                    resultContent.innerHTML = `
          <p class="text-red-400 text-sm font-medium">Error</p>
          <p class="text-red-300/70 text-sm mt-1">Failed to check website</p>
        `;
                }
            });
        </script>
    </body>
</html>
